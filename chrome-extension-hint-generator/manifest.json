{
  "manifest_version": 3,
  "name": "Hint Generator",
  "version": "1.0",
  "description": "A Chrome extension that generates hints for competitive programming problems",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}